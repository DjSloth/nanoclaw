#!/usr/bin/env bash
set -uo pipefail

SURFLINE_BASE="https://services.surfline.com"

usage() {
  cat <<'EOF'
Usage: surfline <command> [args]

Commands:
  conditions <spotId>         Current conditions for a spot
  forecast <spotId> [days]    Hourly wave forecast (default: 1 day)
  search <query>              Find spot IDs by name
  region <name> [limit]       Discover subregions and spots by country/region name
  details <spotId>            Full spot profile: break type, crowd, best conditions, etc.
  favorites                   List favorite spots
EOF
  exit 1
}

# Convert degrees to compass direction (16-point)
deg_to_compass() {
  local deg="$1"
  local dirs=(N NNE NE ENE E ESE SE SSE S SSW SW WSW W WNW NW NNW)
  local idx
  idx=$(echo "$deg" | awk '{printf "%d", int(($1 + 11.25) / 22.5) % 16}')
  echo "${dirs[$idx]}"
}

cmd_conditions() {
  local spot_id="${1:?Usage: surfline conditions <spotId>}"
  local url="${SURFLINE_BASE}/kbyg/spots/reports?spotId=${spot_id}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: failed to fetch conditions for ${spot_id}"; exit 1; }

  local name rating
  name=$(echo "$json" | jq -r '.spot.name // "Unknown"')
  rating=$(echo "$json" | jq -r '.forecast.conditions.value // "Unknown"')

  # Spot type from travel details
  local spot_type
  spot_type=$(echo "$json" | jq -r '(.spot.travelDetails.breakType // []) | join(", ") | gsub("_"; " ")' 2>/dev/null)
  [ -z "$spot_type" ] && spot_type="Unknown"

  local wave_min wave_max wave_human
  wave_min=$(echo "$json" | jq -r '.forecast.waveHeight.min // "?"')
  wave_max=$(echo "$json" | jq -r '.forecast.waveHeight.max // "?"')
  wave_human=$(echo "$json" | jq -r '.forecast.waveHeight.humanRelation // ""')

  # Primary swell: period, direction, energy
  local swell_period swell_dir_deg swell_dir energy
  swell_period=$(echo "$json" | jq -r '.forecast.swells[0].period // "?"')
  swell_dir_deg=$(echo "$json" | jq -r '.forecast.swells[0].direction // "null"')
  energy=$(echo "$json" | jq -r '.forecast.swells[0].power // "?"')
  if [ "$swell_dir_deg" != "null" ] && [ "$swell_dir_deg" != "?" ]; then
    swell_dir=$(deg_to_compass "$swell_dir_deg")
  else
    swell_dir="?"
  fi
  # Round energy to integer
  if [ "$energy" != "?" ]; then
    energy=$(echo "$energy" | awk '{printf "%d", $1 + 0.5}')
  fi

  local wind_speed wind_dir_type wind_dir_deg wind_compass wind_gust
  wind_speed=$(echo "$json" | jq -r '.forecast.wind.speed // "?"')
  wind_dir_type=$(echo "$json" | jq -r '.forecast.wind.directionType // "?"')
  wind_dir_deg=$(echo "$json" | jq -r '.forecast.wind.direction // "null"')
  wind_gust=$(echo "$json" | jq -r '.forecast.wind.gust // "?"')
  if [ "$wind_dir_deg" != "null" ] && [ "$wind_dir_deg" != "?" ]; then
    wind_compass=$(deg_to_compass "$wind_dir_deg")
  else
    wind_compass="?"
  fi

  local water_temp
  water_temp=$(echo "$json" | jq -r '.forecast.waterTemp.max // .forecast.waterTemp.min // "?"')

  local tide_current tide_next
  tide_current=$(echo "$json" | jq -r 'if .forecast.tide.current then "\(.forecast.tide.current.type) (\(.forecast.tide.current.height)m)" else "?" end')
  tide_next=$(echo "$json" | jq -r 'if .forecast.tide.next then "\(.forecast.tide.next.type) (\(.forecast.tide.next.height)m)" else "?" end')

  # Read units from the response
  local wave_unit wind_unit temp_unit
  wave_unit=$(echo "$json" | jq -r '.units.waveHeight // "M"')
  wind_unit=$(echo "$json" | jq -r '.units.windSpeed // "KPH"')
  temp_unit=$(echo "$json" | jq -r '.units.temperature // "C"')

  local wave_display="${wave_min}-${wave_max}m"
  [ "$wave_unit" = "FT" ] && wave_display="${wave_min}-${wave_max}ft"
  [ -n "$wave_human" ] && wave_display="${wave_display} (${wave_human})"

  cat <<EOF
${name} [${spot_type}]
  Conditions: ${rating}
  Waves: ${wave_display}
  Swell: ${swell_dir} @ ${swell_period}s | Energy: ${energy} kJ
  Wind: ${wind_compass} ${wind_speed} ${wind_unit} ${wind_dir_type} (gusts ${wind_gust})
  Water temp: ${water_temp}°${temp_unit}
  Tide: ${tide_current} → next: ${tide_next}
EOF
}

cmd_forecast() {
  local spot_id="${1:?Usage: surfline forecast <spotId> [days]}"
  local days="${2:-1}"
  local url="${SURFLINE_BASE}/kbyg/spots/forecasts/wave?spotId=${spot_id}&days=${days}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: failed to fetch forecast for ${spot_id}"; exit 1; }

  echo "${spot_id} — ${days}-day wave forecast"
  echo "---"

  echo "$json" | jq -r '
    .data.wave[]
    | (.timestamp + (.utcOffset * 3600) | todate | split("T") | .[0] + " " + (.[1] | split("+")[0] | split("Z")[0] | .[0:5])) as $time
    | (.swells[0] // {}) as $swell
    | (if ($swell.direction // null) != null then
        (["N","NNE","NE","ENE","E","ESE","SE","SSE","S","SSW","SW","WSW","W","WNW","NW","NNW"]
         | .[(($swell.direction + 11.25) / 22.5 | floor) % 16])
       else "?" end) as $dir
    | "\($time)  \(.surf.min)-\(.surf.max)m  \($dir)@\($swell.period // 0)s  \(.power | round)kJ  consistency:\(.probability | round)%  \(.surf.humanRelation // "")"
  ' 2>/dev/null || echo "Could not parse forecast data"
}

cmd_search() {
  local query="${1:?Usage: surfline search <query>}"
  local encoded_query
  encoded_query=$(printf '%s' "$query" | jq -sRr @uri)
  local url="${SURFLINE_BASE}/search/site?q=${encoded_query}&querySize=5"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: search failed"; exit 1; }

  local count
  count=$(echo "$json" | jq '[.[0].hits.hits // [] | .[]] | length')

  if [ "$count" = "0" ]; then
    echo "No spots found for: ${query}"
    exit 0
  fi

  echo "Search results for: ${query}"
  echo "---"
  echo "$json" | jq -r '
    .[0].hits.hits[]
    | "\(._source.name)  ID: \(._id)"
  '
}

cmd_region() {
  local query="${1:?Usage: surfline region <name> [limit]}"
  local size="${2:-15}"
  local encoded_query
  encoded_query=$(printf '%s' "$query" | jq -sRr @uri)
  local url="${SURFLINE_BASE}/search/site?q=${encoded_query}&querySize=${size}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: search failed"; exit 1; }

  local subregion_count spot_count
  subregion_count=$(echo "$json" | jq '[.[1].hits.hits // [] | .[]] | length')
  spot_count=$(echo "$json" | jq '[.[0].hits.hits // [] | .[]] | length')

  echo "Search: ${query} (${subregion_count} subregions, ${spot_count} spots)"
  echo "---"

  if [ "$subregion_count" -gt 0 ]; then
    echo "Subregions:"
    echo "$json" | jq -r '
      .[1].hits.hits[]
      | "  \(._source.name // ._source.liesIn // "Unknown")  ID: \(._id)"
    '
  fi

  if [ "$spot_count" -gt 0 ]; then
    echo ""
    echo "Spots:"
    echo "$json" | jq -r '
      .[0].hits.hits[]
      | (._source.breadCrumbs // [] | join(" > ")) as $bc
      | "  \(._source.name)  ID: \(._id)" + (if $bc != "" then "  [\($bc)]" else "" end)
    '
  fi

  if [ "$subregion_count" = "0" ] && [ "$spot_count" = "0" ]; then
    echo "No results found for: ${query}"
  fi
}

cmd_details() {
  local spot_id="${1:?Usage: surfline details <spotId>}"
  local url="${SURFLINE_BASE}/kbyg/spots/reports?spotId=${spot_id}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: failed to fetch details for ${spot_id}"; exit 1; }

  local td='.spot.travelDetails'

  local name lat lon
  name=$(echo "$json" | jq -r '.spot.name // "Unknown"')
  lat=$(echo "$json" | jq -r '.spot.lat // "?"')
  lon=$(echo "$json" | jq -r '.spot.lon // "?"')

  local break_type bottom
  break_type=$(echo "$json" | jq -r "($td.breakType // []) | map(gsub(\"_\"; \" \") | ascii_downcase) | join(\", \")" 2>/dev/null)
  [ -z "$break_type" ] && break_type="Unknown"
  bottom=$(echo "$json" | jq -r "($td.bottom.value // []) | join(\", \")" 2>/dev/null)
  [ -z "$bottom" ] && bottom="Unknown"

  local rating_summary rating_desc
  rating_summary=$(echo "$json" | jq -r "$td.spotRating.summary // \"Unknown\"")
  rating_desc=$(echo "$json" | jq -r "$td.spotRating.description // \"\"")

  local ability boards
  ability=$(echo "$json" | jq -r "$td.abilityLevels.summary // \"Unknown\"")
  boards=$(echo "$json" | jq -r "($td.boardTypes // []) | join(\", \")" 2>/dev/null)
  [ -z "$boards" ] && boards="Unknown"

  local crowd_summary crowd_desc local_vibe water_quality
  crowd_summary=$(echo "$json" | jq -r "$td.crowdFactor.summary // \"Unknown\"")
  crowd_desc=$(echo "$json" | jq -r "$td.crowdFactor.description // \"\"")
  local_vibe=$(echo "$json" | jq -r "$td.localVibe.summary // \"Unknown\"")
  water_quality=$(echo "$json" | jq -r "$td.waterQuality.summary // \"Unknown\"")

  local best_season best_size best_swell best_wind best_tide
  best_season=$(echo "$json" | jq -r "($td.best.season.value // []) | join(\", \")" 2>/dev/null)
  [ -z "$best_season" ] && best_season="Unknown"
  best_size=$(echo "$json" | jq -r "$td.best.size.description // \"Unknown\"")
  best_swell=$(echo "$json" | jq -r "$td.best.swellDirection.description // \"Unknown\"")
  best_wind=$(echo "$json" | jq -r "$td.best.windDirection.description // \"Unknown\"")
  best_tide=$(echo "$json" | jq -r "($td.best.tide.value // []) | map(gsub(\"_\"; \" \")) | join(\", \")" 2>/dev/null)
  [ -z "$best_tide" ] && best_tide="Unknown"

  local hazards access description
  hazards=$(echo "$json" | jq -r "$td.hazards // \"None noted\"")
  access=$(echo "$json" | jq -r "$td.access // \"Unknown\"")
  description=$(echo "$json" | jq -r "$td.description // \"\"")

  cat <<EOF
${name}  [${break_type}]
  Location: ${lat}, ${lon}
  Bottom: ${bottom}
  Rating: ${rating_summary}$([ -n "$rating_desc" ] && echo " — ${rating_desc}")

  Ability: ${ability}
  Boards: ${boards}

  Crowd: ${crowd_summary}$([ -n "$crowd_desc" ] && echo " — ${crowd_desc}")
  Local vibe: ${local_vibe}
  Water quality: ${water_quality}

  Best season: ${best_season}
  Best size: ${best_size}
  Best swell: ${best_swell}
  Best wind: ${best_wind}
  Best tide: ${best_tide}

  Hazards: ${hazards}
  Access: ${access}
EOF

  if [ -n "$description" ]; then
    echo ""
    echo "  [Overview]"
    echo "  ${description}"
  fi
}

