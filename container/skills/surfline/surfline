# --- Main ---

command="${1:-}"
shift || true

case "$command" in
  conditions) cmd_conditions "$@" ;;
  forecast)   cmd_forecast "$@" ;;
  search)     cmd_search "$@" ;;
  favorites)  cmd_favorites ;;
  *)          usage ;;
esac
