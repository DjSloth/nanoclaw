# --- Main ---

command="${1:-}"
shift || true

case "$command" in
  conditions) cmd_conditions "$@" ;;
  forecast)   cmd_forecast "$@" ;;
  search)     cmd_search "$@" ;;
  region)     cmd_region "$@" ;;
  details)    cmd_details "$@" ;;
  travel)         cmd_travel "$@" ;;
  travel-search)  cmd_travel_search "$@" ;;
