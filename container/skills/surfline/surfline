#!/usr/bin/env bash
set -uo pipefail

SURFLINE_BASE="https://services.surfline.com"
SG_BASE="https://api.stormglass.io/v2"
SG_PARAMS="swellHeight,swellPeriod,swellDirection,secondarySwellHeight,secondarySwellPeriod,secondarySwellDirection,waveHeight,wavePeriod,waveDirection,windSpeed,windDirection,gust"

# Spot coordinates lookup (for Stormglass calls)
spot_lat_lng() {
  case "$1" in
    584204204e65fad6a7709aa7) echo "32.476 34.882" ;;   # Power Plant / Sdot Yam
    640a665799dd44dd3d0c88df) echo "32.2734 34.8329" ;; # Sandbox / Poleg Beach
    640a6699451905095aa61467) echo "32.7095 34.9413" ;; # Fort / Atlit
    *) echo "" ;;
  esac
}

# Fetch Stormglass hourly data for a lat/lng window. No source filter = all models.
sg_fetch() {
  local lat="$1" lng="$2" start="$3" end="$4"
  local key="${STORMGLASS_API_KEY:-}"
  [ -z "$key" ] && return 1
  curl -sf --max-time 20 \
    "${SG_BASE}/weather/point?lat=${lat}&lng=${lng}&params=${SG_PARAMS}&start=${start}&end=${end}" \
    -H "Authorization: ${key}"
}

# Given a JSON object of model values (e.g. {"noaa":1.06,"ecmwf":1.0,"sg":1.05}),
# compute avg and spread of non-sg sources. Outputs: "avg spread"
sg_spread() {
  echo "$1" | python3 -c "
import sys, json
d = json.load(sys.stdin)
vals = [v for k,v in d.items() if k != 'sg' and isinstance(v, (int,float))]
if len(vals) < 2:
    print('? 0')
else:
    avg = sum(vals)/len(vals)
    spread = max(vals) - min(vals)
    print(f'{avg:.2f} {spread:.2f}')
" 2>/dev/null || echo "? 0"
}

# Confidence badge based on spread
sg_confidence() {
  local spread="$1"
  python3 -c "
s = float('$spread') if '$spread' != '?' else 999
if s < 0.1: print('✅ High')
elif s < 0.25: print('〜 Medium')
else: print('⚠️ Low')
" 2>/dev/null || echo "〜"
}

# Source names present (excluding 'sg')
sg_sources() {
  echo "$1" | python3 -c "
import sys, json
d = json.load(sys.stdin)
srcs = sorted(k.upper() for k in d if k != 'sg' and isinstance(d[k], (int,float)))
print('/'.join(srcs))
" 2>/dev/null || echo "?"
}

# Compass from degrees
deg2c() {
  python3 -c "
dirs=['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW']
print(dirs[round(float('$1')/22.5)%16])
" 2>/dev/null || echo "?"
}

usage() {
  cat <<'EOF'
Usage: surfline <command> [args]

Commands:
  conditions <spotId>         Current conditions for a spot
  forecast <spotId> [days]    Hourly wave forecast (default: 1 day)
  search <query>              Find spot IDs by name
  region <name> [limit]       Discover subregions and spots by country/region name
  details <spotId>            Full spot profile: break type, crowd, best conditions, etc.
  travel <slug-or-id>          Travel zone guide: seasons, spots, tips
  travel-search <query>        Search travel zones by name (uses local cache if available)
  travel-scan                  Fetch all travel zones from Surfline and update local cache CSV
  favorites                   List favorite spots
EOF
  exit 1
}

# Convert degrees to compass direction (16-point)
deg_to_compass() {
  local deg="$1"
  local dirs=(N NNE NE ENE E ESE SE SSE S SSW SW WSW W WNW NW NNW)
  local idx
  idx=$(echo "$deg" | awk '{printf "%d", int(($1 + 11.25) / 22.5) % 16}')
  echo "${dirs[$idx]}"
}

cmd_conditions() {
  local spot_id="${1:?Usage: surfline conditions <spotId>}"
  local url="${SURFLINE_BASE}/kbyg/spots/reports?spotId=${spot_id}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: failed to fetch conditions for ${spot_id}"; exit 1; }

  local name rating
  name=$(echo "$json" | jq -r '.spot.name // "Unknown"')
  rating=$(echo "$json" | jq -r '.forecast.conditions.value // "Unknown"')

  # Spot type from travel details
  local spot_type
  spot_type=$(echo "$json" | jq -r '(.spot.travelDetails.breakType // []) | join(", ") | gsub("_"; " ")' 2>/dev/null)
  [ -z "$spot_type" ] && spot_type="Unknown"

  local wave_min wave_max wave_human
  wave_min=$(echo "$json" | jq -r '.forecast.waveHeight.min // "?"')
  wave_max=$(echo "$json" | jq -r '.forecast.waveHeight.max // "?"')
  wave_human=$(echo "$json" | jq -r '.forecast.waveHeight.humanRelation // ""')

  # Primary swell: period, direction, energy
  local swell_period swell_dir_deg swell_dir energy
  swell_period=$(echo "$json" | jq -r '.forecast.swells[0].period // "?"')
  swell_dir_deg=$(echo "$json" | jq -r '.forecast.swells[0].direction // "null"')
  energy=$(echo "$json" | jq -r '.forecast.swells[0].power // "?"')
  if [ "$swell_dir_deg" != "null" ] && [ "$swell_dir_deg" != "?" ]; then
    swell_dir=$(deg_to_compass "$swell_dir_deg")
  else
    swell_dir="?"
  fi
  # Round energy to integer
  if [ "$energy" != "?" ]; then
    energy=$(echo "$energy" | awk '{printf "%d", $1 + 0.5}')
  fi

  local wind_speed wind_dir_type wind_dir_deg wind_compass wind_gust
  wind_speed=$(echo "$json" | jq -r '.forecast.wind.speed // "?"')
  wind_dir_type=$(echo "$json" | jq -r '.forecast.wind.directionType // "?"')
  wind_dir_deg=$(echo "$json" | jq -r '.forecast.wind.direction // "null"')
  wind_gust=$(echo "$json" | jq -r '.forecast.wind.gust // "?"')
  if [ "$wind_dir_deg" != "null" ] && [ "$wind_dir_deg" != "?" ]; then
    wind_compass=$(deg_to_compass "$wind_dir_deg")
  else
    wind_compass="?"
  fi

  local water_temp
  water_temp=$(echo "$json" | jq -r '.forecast.waterTemp.max // .forecast.waterTemp.min // "?"')

  local tide_current tide_next
  tide_current=$(echo "$json" | jq -r 'if .forecast.tide.current then "\(.forecast.tide.current.type) (\(.forecast.tide.current.height)m)" else "?" end')
  tide_next=$(echo "$json" | jq -r 'if .forecast.tide.next then "\(.forecast.tide.next.type) (\(.forecast.tide.next.height)m)" else "?" end')

  # Read units from the response
  local wave_unit wind_unit temp_unit
  wave_unit=$(echo "$json" | jq -r '.units.waveHeight // "M"')
  wind_unit=$(echo "$json" | jq -r '.units.windSpeed // "KPH"')
  temp_unit=$(echo "$json" | jq -r '.units.temperature // "C"')

  local wave_display="${wave_min}-${wave_max}m"
  [ "$wave_unit" = "FT" ] && wave_display="${wave_min}-${wave_max}ft"
  [ -n "$wave_human" ] && wave_display="${wave_display} (${wave_human})"

  # Lat/lon for Stormglass
  local spot_lat spot_lon
  spot_lat=$(echo "$json" | jq -r '.spot.lat // ""')
  spot_lon=$(echo "$json" | jq -r '.spot.lon // ""')

  cat <<EOF
${name} [${spot_type}]
  Conditions: ${rating}
  Waves: ${wave_display}
  Swell: ${swell_dir} @ ${swell_period}s | Energy: ${energy} kJ
  Wind: ${wind_compass} ${wind_speed} ${wind_unit} ${wind_dir_type} (gusts ${wind_gust})
  Water temp: ${water_temp}°${temp_unit}
  Tide: ${tide_current} → next: ${tide_next}
EOF

  # Stormglass model consensus (Option B)
  if [ -n "${STORMGLASS_API_KEY:-}" ] && [ -n "$spot_lat" ] && [ -n "$spot_lon" ]; then
    local now end_ts sg_json
    now=$(date -u +%s)
    end_ts=$((now + 3600))
    sg_json=$(sg_fetch "$spot_lat" "$spot_lon" "$now" "$end_ts" 2>/dev/null) || sg_json=""

    if [ -n "$sg_json" ] && echo "$sg_json" | jq -e '.hours[0]' >/dev/null 2>&1; then
      local hr
      hr=$(echo "$sg_json" | jq '.hours[0]')

      # sg = Stormglass AI-blended value (authoritative). Spread of raw models = confidence.
      local wh_json wh_sg wh_spread wh_conf wh_sources
      wh_json=$(echo "$hr" | jq -c '.waveHeight // {}')
      wh_sg=$(echo "$hr"  | jq -r '.waveHeight.sg // "?"')
      wh_spread=$(sg_spread "$wh_json" | awk '{print $2}')
      wh_conf=$(sg_confidence "$wh_spread")
      wh_sources=$(sg_sources "$wh_json")

      # Primary swell (sg values)
      local sw_h sw_p sw_d_deg sw_d_comp
      sw_h=$(echo "$hr" | jq -r '.swellHeight.sg // "?"')
      sw_p=$(echo "$hr" | jq -r '.swellPeriod.sg // "?"')
      sw_d_deg=$(echo "$hr" | jq -r '.swellDirection.sg // ""')
      sw_d_comp=""
      [ -n "$sw_d_deg" ] && sw_d_comp=$(deg2c "$sw_d_deg")

      # Secondary swell (sg values)
      local sw2_h sw2_p sw2_d_deg sw2_d_comp
      sw2_h=$(echo "$hr" | jq -r '.secondarySwellHeight.sg // "?"')
      sw2_p=$(echo "$hr" | jq -r '.secondarySwellPeriod.sg // "?"')
      sw2_d_deg=$(echo "$hr" | jq -r '.secondarySwellDirection.sg // ""')
      sw2_d_comp=""
      [ -n "$sw2_d_deg" ] && sw2_d_comp=$(deg2c "$sw2_d_deg")

      # Wind (sg = AI-blended, m/s → kph)
      local sg_wind_spd sg_wind_dir_deg sg_wind_dir_comp sg_gust sg_wind_kph sg_gust_kph
      sg_wind_spd=$(echo "$hr" | jq -r '.windSpeed.sg // "?"')
      sg_wind_dir_deg=$(echo "$hr" | jq -r '.windDirection.sg // ""')
      sg_wind_dir_comp=""
      [ -n "$sg_wind_dir_deg" ] && sg_wind_dir_comp=$(deg2c "$sg_wind_dir_deg")
      sg_gust=$(echo "$hr" | jq -r '.gust.sg // "?"')
      sg_wind_kph=$(python3 -c "print(round(float('$sg_wind_spd') * 3.6, 1))" 2>/dev/null || echo "$sg_wind_spd")
      sg_gust_kph=$(python3 -c "print(round(float('$sg_gust') * 3.6, 1))" 2>/dev/null || echo "$sg_gust")

      echo "  ╌╌ Stormglass AI [models: ${wh_sources}] ╌╌"
      echo "  Wave: ${wh_sg}m  model spread ±${wh_spread}m  ${wh_conf} confidence"
      echo "  Swell: ${sw_d_comp} ${sw_d_deg}° @ ${sw_p}s ${sw_h}m  |  2nd: ${sw2_d_comp} @ ${sw2_p}s ${sw2_h}m"
      echo "  Wind: ${sg_wind_dir_comp} ${sg_wind_kph}kph (gusts ${sg_gust_kph}kph)"
    fi
  fi
}

cmd_forecast() {
  local spot_id="${1:?Usage: surfline forecast <spotId> [days]}"
  local days="${2:-1}"
  local tok="${SURFLINE_ACCESS_TOKEN:-}"

  # Build URLs — use accesstoken param when available for corrected/premium data
  local auth_param=""
  [ -n "$tok" ] && auth_param="&accesstoken=${tok}"

  local wave_url="${SURFLINE_BASE}/kbyg/spots/forecasts/wave?spotId=${spot_id}&days=${days}${auth_param}"
  local wind_url="${SURFLINE_BASE}/kbyg/spots/forecasts/wind?spotId=${spot_id}&days=${days}&corrected=true&units%5BwindSpeed%5D=KPH${auth_param}"
  local rating_url="${SURFLINE_BASE}/kbyg/spots/forecasts/rating?spotId=${spot_id}&days=${days}${auth_param}"
  local swells_url="${SURFLINE_BASE}/kbyg/spots/forecasts/swells?spotId=${spot_id}&days=${days}&units%5BswellHeight%5D=M${auth_param}"
  local sunlight_url="${SURFLINE_BASE}/kbyg/spots/forecasts/sunlight?spotId=${spot_id}&days=${days}${auth_param}"

  local wave_json wind_json rating_json swells_json sunlight_json consistency_json
  wave_json=$(curl -sf --max-time 15 "$wave_url") || { echo "Error: failed to fetch wave forecast for ${spot_id}"; exit 1; }
  wind_json=$(curl -sf --max-time 15 "$wind_url") || { echo "Error: failed to fetch wind forecast for ${spot_id}"; exit 1; }
  rating_json=$(curl -sf --max-time 15 "$rating_url") || { echo "Error: failed to fetch rating forecast for ${spot_id}"; exit 1; }
  swells_json=$(curl -sf --max-time 15 "$swells_url" 2>/dev/null || echo '{"data":{"swells":[]}}')
  sunlight_json=$(curl -sf --max-time 15 "$sunlight_url" 2>/dev/null || echo '{"data":{"sunlight":[]}}')

  # Consistency requires access token (premium endpoint)
  if [ -n "$tok" ]; then
    local consistency_url="${SURFLINE_BASE}/kbyg/spots/forecasts/consistency?spotId=${spot_id}&days=${days}&intervalHours=1&accesstoken=${tok}"
    consistency_json=$(curl -sf --max-time 15 "$consistency_url" 2>/dev/null || echo '{"data":{"consistency":[]}}')
  else
    consistency_json='{"data":{"consistency":[]}}'
  fi

  # Stormglass — one call for the full forecast window (Option C)
  local sg_json="" sg_by_hour="{}"
  local coords
  coords=$(spot_lat_lng "$spot_id")
  if [ -n "${STORMGLASS_API_KEY:-}" ] && [ -n "$coords" ]; then
    local sg_lat sg_lng
    sg_lat=$(echo "$coords" | awk '{print $1}')
    sg_lng=$(echo "$coords" | awk '{print $2}')
    local now end_ts
    now=$(date -u +%s)
    end_ts=$((now + days * 86400))
    sg_json=$(sg_fetch "$sg_lat" "$sg_lng" "$now" "$end_ts" 2>/dev/null) || sg_json=""
    if [ -n "$sg_json" ] && echo "$sg_json" | jq -e '.hours' >/dev/null 2>&1; then
      # Build hour-keyed lookup: unix_timestamp -> {waveHeight, swellHeight, swellPeriod, swellDirection, spread}
      sg_by_hour=$(echo "$sg_json" | python3 -c "
import sys, json
from datetime import datetime, timezone
data = json.load(sys.stdin)
out = {}
for hr in data.get('hours', []):
    t = hr.get('time', '')
    # parse ISO time to unix
    try:
        dt = datetime.fromisoformat(t.replace('Z', '+00:00'))
        ts = int(dt.timestamp())
    except:
        continue
    def spread(param):
        d = hr.get(param, {})
        vals = [v for k,v in d.items() if k != 'sg' and isinstance(v, (int,float))]
        if len(vals) < 2: return 0.0
        return round(max(vals)-min(vals), 2)
    def sg(param):
        return hr.get(param, {}).get('sg', None)
    out[str(ts)] = {
        'wh': sg('waveHeight'),
        'wh_spread': spread('waveHeight'),
        'sh': sg('swellHeight'),
        'sp': sg('swellPeriod'),
        'sd': sg('swellDirection'),
        'wsp': sg('windSpeed'),
        'wdir': sg('windDirection'),
        'gust': sg('gust'),
    }
print(json.dumps(out))
" 2>/dev/null || echo "{}")
    fi
  fi

  echo "${spot_id} — ${days}-day forecast"
  [ -n "$sg_json" ] && echo "(+ Stormglass AI cross-reference  sg=AI-blended  ±spread=model agreement)"
  echo "---"

  # Print sunrise/sunset times as header per day
  echo "$sunlight_json" | jq -r '
    .data.sunlight[]?
    | (.sunrise + (.sunriseUTCOffset * 3600) | todate | split("T")[1][0:5]) as $rise
    | (.sunset  + (.sunsetUTCOffset  * 3600) | todate | split("T")[1][0:5]) as $set
    | (.midnight + (.midnightUTCOffset * 3600) | todate | split("T")[0]) as $day
    | "\($day)  🌅 \($rise)  🌇 \($set)"
  ' 2>/dev/null
  echo ""

  # Build base forecast with Stormglass overlay via Python (handles JSON merge cleanly)
  echo "$wave_json" "$wind_json" "$rating_json" "$swells_json" "$consistency_json" | jq -rs '
    def deg2c(d): ["N","NNE","NE","ENE","E","ESE","SE","SSE","S","SSW","SW","WSW","W","WNW","NW","NNW"]
                  | .[(((d + 11.25) / 22.5) | floor) % 16];

    (.[1].data.wind       | map({key: (.timestamp | tostring), value: .}) | from_entries) as $wind
    | (.[2].data.rating   | map({key: (.timestamp | tostring), value: .}) | from_entries) as $rating
    | (.[3].data.swells   | map({key: (.timestamp | tostring), value: .}) | from_entries) as $swells
    | (.[4].data.consistency | map({key: (.timestamp | tostring), value: .}) | from_entries) as $consist
    | .[0].data.wave[]
    | (.timestamp + (.utcOffset * 3600) | todate | split("T") | .[0] + " " + (.[1] | split("+")[0] | split("Z")[0] | .[0:5])) as $time
    | (.swells[0] // {}) as $swell0
    | ($swells[(.timestamp | tostring)] // {swells: []}) as $sw
    | ($sw.swells // [] | map(select(.impact > 0)) | sort_by(-.impact) | .[0] // $swell0) as $primary
    | (if ($primary.direction // null) != null then deg2c($primary.direction) else "?" end) as $dir
    | ($wind[(.timestamp | tostring)] // {}) as $w
    | (if ($w.direction // null) != null then deg2c($w.direction) else "?" end) as $wdir
    | ($rating[(.timestamp | tostring)].rating // {}) as $r
    | ($consist[(.timestamp | tostring)].consistency.waveCount // null) as $c
    | "\(.timestamp)|\($time)  [\($r.value // "?")/5 \($r.key // "?")]  \(.surf.min)-\(.surf.max)m  \($dir)@\($primary.period // 0)s  \(.power | round)kJ\(if $c != null then "  consistency:\($c | round)%" else "" end)  wind:\($wdir) \($w.speed // "?" | if type=="number" then round else . end)kph(\($w.directionType // "?"))  \(.surf.humanRelation // "")"
  ' 2>/dev/null | python3 -c "
import sys, json

sg = json.loads('''${sg_by_hour}'''.replace('\\'', '\"'))

def conf(spread):
    if spread < 0.1: return '✅'
    elif spread < 0.25: return '〜'
    else: return '⚠️'

def deg2c(d):
    dirs=['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW']
    return dirs[round(d/22.5)%16]

for line in sys.stdin:
    line = line.rstrip()
    if '|' not in line:
        print(line)
        continue
    ts_str, rest = line.split('|', 1)
    ts = ts_str.strip()
    sg_hr = sg.get(ts, {})
    suffix = ''
    if sg_hr:
        wh = sg_hr.get('wh')
        spread = sg_hr.get('wh_spread', 0)
        if wh is not None:
            badge = conf(spread)
            suffix = f'  [SG:{wh:.1f}m±{spread:.2f} {badge}]'
    print(rest + suffix)
" 2>/dev/null || echo "Could not parse forecast data"
}

cmd_search() {
  local query="${1:?Usage: surfline search <query>}"
  local encoded_query
  encoded_query=$(printf '%s' "$query" | jq -sRr @uri)
  local url="${SURFLINE_BASE}/search/site?q=${encoded_query}&querySize=5"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: search failed"; exit 1; }

  local count
  count=$(echo "$json" | jq '[.[0].hits.hits // [] | .[]] | length')

  if [ "$count" = "0" ]; then
    echo "No spots found for: ${query}"
    exit 0
  fi

  echo "Search results for: ${query}"
  echo "---"
  echo "$json" | jq -r '
    .[0].hits.hits[]
    | "\(._source.name)  ID: \(._id)"
  '
}

cmd_region() {
  local query="${1:?Usage: surfline region <name> [limit]}"
  local size="${2:-15}"
  local encoded_query
  encoded_query=$(printf '%s' "$query" | jq -sRr @uri)
  local url="${SURFLINE_BASE}/search/site?q=${encoded_query}&querySize=${size}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: search failed"; exit 1; }

  local subregion_count spot_count
  subregion_count=$(echo "$json" | jq '[.[1].hits.hits // [] | .[]] | length')
  spot_count=$(echo "$json" | jq '[.[0].hits.hits // [] | .[]] | length')

  echo "Search: ${query} (${subregion_count} subregions, ${spot_count} spots)"
  echo "---"

  if [ "$subregion_count" -gt 0 ]; then
    echo "Subregions:"
    echo "$json" | jq -r '
      .[1].hits.hits[]
      | "  \(._source.name // ._source.liesIn // "Unknown")  ID: \(._id)"
    '
  fi

  if [ "$spot_count" -gt 0 ]; then
    echo ""
    echo "Spots:"
    echo "$json" | jq -r '
      .[0].hits.hits[]
      | (._source.breadCrumbs // [] | join(" > ")) as $bc
      | "  \(._source.name)  ID: \(._id)" + (if $bc != "" then "  [\($bc)]" else "" end)
    '
  fi

  if [ "$subregion_count" = "0" ] && [ "$spot_count" = "0" ]; then
    echo "No results found for: ${query}"
  fi
}

cmd_details() {
  local spot_id="${1:?Usage: surfline details <spotId>}"
  local url="${SURFLINE_BASE}/kbyg/spots/reports?spotId=${spot_id}"

  local json
  json=$(curl -sf --max-time 15 "$url") || { echo "Error: failed to fetch details for ${spot_id}"; exit 1; }

  local td='.spot.travelDetails'

  local name lat lon
  name=$(echo "$json" | jq -r '.spot.name // "Unknown"')
  lat=$(echo "$json" | jq -r '.spot.lat // "?"')
  lon=$(echo "$json" | jq -r '.spot.lon // "?"')

  local break_type bottom
  break_type=$(echo "$json" | jq -r "($td.breakType // []) | map(gsub(\"_\"; \" \") | ascii_downcase) | join(\", \")" 2>/dev/null)
  [ -z "$break_type" ] && break_type="Unknown"
  bottom=$(echo "$json" | jq -r "($td.bottom.value // []) | join(\", \")" 2>/dev/null)
  [ -z "$bottom" ] && bottom="Unknown"

  local rating_summary rating_desc
  rating_summary=$(echo "$json" | jq -r "$td.spotRating.summary // \"Unknown\"")
  rating_desc=$(echo "$json" | jq -r "$td.spotRating.description // \"\"")

  local ability boards
  ability=$(echo "$json" | jq -r "$td.abilityLevels.summary // \"Unknown\"")
  boards=$(echo "$json" | jq -r "($td.boardTypes // []) | join(\", \")" 2>/dev/null)
  [ -z "$boards" ] && boards="Unknown"

  local crowd_summary crowd_desc local_vibe water_quality
  crowd_summary=$(echo "$json" | jq -r "$td.crowdFactor.summary // \"Unknown\"")
  crowd_desc=$(echo "$json" | jq -r "$td.crowdFactor.description // \"\"")
  local_vibe=$(echo "$json" | jq -r "$td.localVibe.summary // \"Unknown\"")
  water_quality=$(echo "$json" | jq -r "$td.waterQuality.summary // \"Unknown\"")

  local best_season best_size best_swell best_wind best_tide
  best_season=$(echo "$json" | jq -r "($td.best.season.value // []) | join(\", \")" 2>/dev/null)
  [ -z "$best_season" ] && best_season="Unknown"
  best_size=$(echo "$json" | jq -r "$td.best.size.description // \"Unknown\"")
  best_swell=$(echo "$json" | jq -r "$td.best.swellDirection.description // \"Unknown\"")
  best_wind=$(echo "$json" | jq -r "$td.best.windDirection.description // \"Unknown\"")
  best_tide=$(echo "$json" | jq -r "($td.best.tide.value // []) | map(gsub(\"_\"; \" \")) | join(\", \")" 2>/dev/null)
  [ -z "$best_tide" ] && best_tide="Unknown"

  local hazards access description
  hazards=$(echo "$json" | jq -r "$td.hazards // \"None noted\"")
  access=$(echo "$json" | jq -r "$td.access // \"Unknown\"")
  description=$(echo "$json" | jq -r "$td.description // \"\"")

  cat <<EOF
${name}  [${break_type}]
  Location: ${lat}, ${lon}
  Bottom: ${bottom}
  Rating: ${rating_summary}$([ -n "$rating_desc" ] && echo " — ${rating_desc}")

  Ability: ${ability}
  Boards: ${boards}

  Crowd: ${crowd_summary}$([ -n "$crowd_desc" ] && echo " — ${crowd_desc}")
  Local vibe: ${local_vibe}
  Water quality: ${water_quality}

  Best season: ${best_season}
  Best size: ${best_size}
  Best swell: ${best_swell}
  Best wind: ${best_wind}
  Best tide: ${best_tide}

  Hazards: ${hazards}
  Access: ${access}
EOF

  if [ -n "$description" ]; then
    echo ""
    echo "  [Overview]"
    # Convert <br> to newlines, strip remaining tags, decode entities
    printf "%s\n" "$description" \
      | sed 's/<\/\?br[^>]*>/\n/g' \
      | sed 's/<[^>]*>//g' \
      | sed 's/&amp;/\&/g; s/&lt;/</g; s/&gt;/>/g; s/&nbsp;/ /g' \
      | sed '/^[[:space:]]*$/d' \
      | sed 's/^/  /'
  fi
}

