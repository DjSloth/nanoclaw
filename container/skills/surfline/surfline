# --- Main ---

command="${1:-}"
shift || true

case "$command" in
  conditions) cmd_conditions "$@" ;;
  forecast)   cmd_forecast "$@" ;;
  search)     cmd_search "$@" ;;
  region)     cmd_region "$@" ;;
  details)    cmd_details "$@" ;;
  favorites)  cmd_favorites ;;
  *)          usage ;;
esac
