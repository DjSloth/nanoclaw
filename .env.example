
# Google Workspace CLI — active account for containers
# Point to the exported credentials file for the account you want agents to use.
# Run `gws auth export --unmasked > ~/.config/gws/creds-<account>.json` to create these.
# The path here uses the container-internal path (/home/node/.config/gws/).
#
# Available accounts:
#   /home/node/.config/gws/creds-slothlabs.json  (raz@slothlabs.dev)
#   /home/node/.config/gws/creds-gmail.json       (dotanraz@gmail.com)
#   /home/node/.config/gws/creds-invocap.json     (dotan@invocap.com)
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/home/node/.config/gws/creds-slothlabs.json
